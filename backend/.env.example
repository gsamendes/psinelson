# Porta do servidor HTTP
PORT=3333

# Ambiente: development | test | production
NODE_ENV=development

# Conexão PostgreSQL (Neon no deploy). Formato Prisma:
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/psiapp?schema=public"

# Segredo para assinar os JWT (troque em produção!)
JWT_SECRET="troque-este-segredo-em-producao"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Origem permitida no CORS (frontend). Use "*" só em desenvolvimento.
CORS_ORIGIN="http://localhost:5173"
